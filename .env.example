# Секреты: скопируйте в .env и заполните. В config.yaml можно оставить пустые token/account_id.
TINKOFF_TOKEN=
TINKOFF_ACCOUNT_ID=
TELEGRAM_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Опционально: целевой баланс в песочнице (RUB)
# SANDBOX_TARGET_CASH=100000
# Режим без реальных заявок
# DRY_RUN=false
# DeepSeek API (legacy — LLM теперь через OpenRouter)
# DEEPSEEK_API_KEY=
# Finam Trade API (количественный советник, https://api.finam.ru)
# FINAM_API_TOKEN=
# OpenRouter — единый LLM-шлюз (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=
# Gemini/Groq — не нужны, модели доступны через OpenRouter
# GEMINI_API_KEY=
# GROQ_API_KEY=

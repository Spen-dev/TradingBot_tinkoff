# Секреты: скопируйте в .env и заполните. В config.yaml можно оставить пустые token/account_id.
TINKOFF_TOKEN=
TINKOFF_ACCOUNT_ID=
TELEGRAM_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Опционально: целевой баланс в песочнице (RUB)
# SANDBOX_TARGET_CASH=100000
# Режим без реальных заявок
# DRY_RUN=false
# DeepSeek API (динамический портфель и LLM-советник)
# DEEPSEEK_API_KEY=
# Finam Trade API (количественный советник, https://api.finam.ru)
# FINAM_API_TOKEN=
# Google Gemini (бесплатный tier, https://aistudio.google.com/apikey)
# GEMINI_API_KEY=
# Groq (бесплатный tier, https://console.groq.com)
# GROQ_API_KEY=
# OpenRouter (бесплатные :free модели, https://openrouter.ai/keys)
# OPENROUTER_API_KEY=
